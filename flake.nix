{
  description = "A flake to build containers";
  inputs = {
    nixpkgs.url = "github:nixos/nixpkgs";
  };

  outputs = { self, nixpkgs }: let
    system = "x86_64-linux"; # Containers must be built for Linux
    pkgs = nixpkgs.legacyPackages.${system};
    lib = pkgs.lib;
    ## Create a custom etc/doas.conf file for the container
    #doasConf = pkgs.writeTextDir "etc/doas.conf" ''
    #  permit nopass :wheel
    #  permit keepenv :wheel
    #'';
    fakeSudo = pkgs.writeScriptBin "sudo" ''
    #!/bin/sh
    # Just pass the command through without elevation
    exec "$@"
    '';
    lz4C = pkgs.writeScriptBin "lz4c" ''
    #!/bin/sh
    # Just pass the command through without elevation
    exec "lz4 $@"
    '';

    sharedPkgs = import ./packages.nix { inherit pkgs; } ++ [ fakeSudo lz4C ];

    # Example: Creating a basic FHS shell
    fhs = pkgs.buildFHSEnv {
      name = "my-fhs-env";
      targetPkgs = pkgs: sharedPkgs ++ [
        # 1. Create a Python environment that includes the missing module
        (pkgs.python3.withPackages (ps: with ps; [
          argcomplete
          # add other modules here
        ]))
      ];

      runScript = "bash";
    };

    # 1. Define the "FHS-like" environment
    fhsLayout = pkgs.buildEnv {
      name = "fhs-root-layout";
      # List all packages you want in the standard paths
      paths = sharedPkgs;
      # 2. Tell Nix which folders to symlink to the root
      pathsToLink = [ "/bin" "/etc" "/include" "/lib" "/share" "/usr" "/var" ];
      # Either package priority or this (see glibc.dev in packages.nix)
      #ignoreCollisions = true;
    };

    # Create a wrapper that moves /include to /usr/include
    usrInclude = pkgs.runCommand "usr-include" {} ''
      mkdir -p $out/usr
      ln -s ${fhsLayout}/include $out/usr/include
    '';

  in {
/*
    devShells.${system}.default = pkgs.mkShell {
      name = "fhs-like-shell";

      # 3. Add the tree to the shell
      buildInputs = [ fhsLayout ];

      # 4. Manually set the variables so binaries find their dependencies
      shellHook = ''
        # Point to the symlinked tree in the Nix store
        export FHS_ROOT=${fhsLayout}

        # Add the FHS paths to the front of your environment
        export PATH="$FHS_ROOT/bin:$PATH"
        export LD_LIBRARY_PATH="$FHS_ROOT/lib:$LD_LIBRARY_PATH"
        export C_INCLUDE_PATH="$FHS_ROOT/include:$C_INCLUDE_PATH"
        export CPLUS_INCLUDE_PATH="$FHS_ROOT/include:$CPLUS_INCLUDE_PATH"

        echo "FHS-like environment loaded at $FHS_ROOT"
      '';
    };
*/

    # Example: Creating a basic FHS shell
    devShells.${system}.default = fhs.env;

    packages.${system}.container = pkgs.dockerTools.buildImage {
      name = "minix-container";
      tag = "latest";
      # This (now) breaks reproducibility:
      #created = "now";
      # Contents to include in the image root
      # 3. Drop the symlinked tree into the container root
      copyToRoot = [
        fhsLayout
        usrInclude  # Provides /usr/include -> /bin/include
        pkgs.dockerTools.binSh
        pkgs.dockerTools.usrBinEnv
        pkgs.dockerTools.caCertificates
        pkgs.dockerTools.fakeNss
      ];

      config = {
        Cmd = [ "/bin/bash" ];
        Env = [
          "TZDIR=/share/zoneinfo"
          "LANG=en_US.UTF-8"
          "LANGUAGE=en_US:en"
          "LC_ALL=en_US.UTF-8"
          # Point to the locale archive generated by glibcLocales
          "LOCALE_ARCHIVE=/lib/locale/locale-archive"
          # 4. Standard Linux paths so the container knows where to look
          "LD_LIBRARY_PATH=/lib:/usr/lib"
          "PATH=/bin:/usr/bin"
        ];
      };
    };

/*orig:
    packages.${system}.container = pkgs.dockerTools.buildImage {
      name = "mynix-container";
      tag = "latest";
      # This (now) breaks reproducibility:
      #created = "now";
      # Contents to include in the image root
      copyToRoot = pkgs.buildEnv {
        name = "image-root";
        paths = sharedPkgs;
        pathsToLink = [ "/bin" "/etc" "/lib/locale" "/share" "/usr/bin" "/var" ];
      };

      # This runs during the image build to create the necessary symlink
      #does not have enough perimissions: extraCommands = ''
      runAsRoot = ''
        mkdir -p share
        ln -sf ${pkgs.tzdata}/share/zoneinfo share/zoneinfo

        # Optional: Set a default local time
        mkdir -p etc
        ln -sf /share/zoneinfo/Europe/Ljubljana etc/localtime

        # Provide glibc headers:
        ln -sf ${pkgs.glibc.dev}/include /usr/include

        #rm -f /etc/group
        #rm -f /etc/passwd
      '';

      config = {
        Env = [
          "TZDIR=/share/zoneinfo"
          "LANG=en_US.UTF-8"
          "LANGUAGE=en_US:en"
          "LC_ALL=en_US.UTF-8"
          # Point to the locale archive generated by glibcLocales
          "LOCALE_ARCHIVE=/lib/locale/locale-archive"
          #"BB_ENV_PASSTHROUGH_ADDITIONS=LC_ALL LOCALE_ARCHIVE"
          "BB_ENV_PASSTHROUGH=BB_TASKHASH HOME LOGNAME PATH PWD SHELL USER LOCALE_ARCHIVE LC_ALL BBSERVER"
        ];
        Cmd = [ "/bin/bash" ];
      };
    };
*/
  };
}

